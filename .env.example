# 数据库配置
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/attendance_system

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# JWT配置
JWT_SECRET_KEY=your-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# 华为云配置
HWC_AK=your-access-key
HWC_SK=your-secret-key
HWC_PROJECT_ID=your-project-id
HWC_REGION_NAME=cn-north-4

# FRS服务配置
FRS_FACE_SET_NAME=attendance_system_faces
FRS_SIMILARITY_THRESHOLD=0.8
FRS_MAX_FACES_RETURNED=1

# 应用配置
APP_NAME=Facial Recognition Attendance System
APP_VERSION=1.0.0
DEBUG=False
LOG_LEVEL=INFO

# 限流配置
RATE_LIMIT_PER_USER_5SEC=1
RATE_LIMIT_SIGN_IN_PER_DAY=100

# 文件上传配置
MAX_UPLOAD_SIZE=10485760
ALLOWED_IMAGE_TYPES=image/jpeg,image/png
IMAGE_UPLOAD_DIR=/var/uploads/attendance
